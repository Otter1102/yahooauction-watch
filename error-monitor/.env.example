# Discord Bot トークン
# 取得方法: https://discord.com/developers/applications → New Application → Bot → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here

# 監視するチャンネルID
# 取得方法: Discordでチャンネルを右クリック → チャンネルIDをコピー（開発者モードをONに）
DISCORD_CHANNEL_ID=your_channel_id_here

# Ollama設定（デフォルトのまま変更不要）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ヤフオクwatch-appのパス（vercel --prod実行用）
YAHOOWATCH_DIR=/Users/sawadaakira/Library/Mobile Documents/com~apple~CloudDocs/Obsidian Vault/services/web-apps/ヤフオクwatch-app
