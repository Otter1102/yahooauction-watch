{
  "functions": {
    "app/api/cron/coordinator/route.ts":   { "maxDuration": 60 },
    "app/api/cron/check/route.ts":         { "maxDuration": 60 },
    "app/api/cron/check/[shard]/route.ts": { "maxDuration": 60 },
    "app/api/conditions/route.ts":         { "maxDuration": 60 },
    "app/api/conditions/[id]/route.ts":    { "maxDuration": 60 },
    "app/api/run-now/route.ts":            { "maxDuration": 60 },
    "app/api/run/[id]/route.ts":           { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/check/0", "schedule": "12 * * * *" },
    { "path": "/api/cron/check/1", "schedule": "13 * * * *" },
    { "path": "/api/cron/check/2", "schedule": "14 * * * *" },
    { "path": "/api/cron/check/3", "schedule": "15 * * * *" },
    { "path": "/api/cron/check/4", "schedule": "16 * * * *" },
    { "path": "/api/cron/check/5", "schedule": "17 * * * *" },
    { "path": "/api/cron/check/6", "schedule": "18 * * * *" },
    { "path": "/api/cron/check/7", "schedule": "19 * * * *" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ]
}
