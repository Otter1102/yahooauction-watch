{
  "crons": [
    {
      "path": "/api/cron/check",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/cron/coordinator/route.ts":   { "maxDuration": 60 },
    "app/api/cron/check/route.ts":         { "maxDuration": 60 },
    "app/api/cron/check/[shard]/route.ts": { "maxDuration": 60 },
    "app/api/run-now/route.ts":            { "maxDuration": 60 },
    "app/api/run/[id]/route.ts":           { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ]
}
