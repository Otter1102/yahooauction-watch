# yahoo-auction-watcher 環境変数テンプレート
# 実値は .env.main / .env.local に書く（git 管理外）
# Vercel 連携の値は `vercel env pull .env.main` で取得すること

# Vercel OIDC Token (Vercel CLI が自動で書き込む — 手動編集不要)
VERCEL_OIDC_TOKEN=

# notified_items の逃がし先（Upstash Redis）
# 未設定なら従来通りSupabaseの notified_items を使う。
NOTIFIED_ITEMS_STORE=auto
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NOTIFIED_REDIS_PREFIX=notified:v1

# notification_history の逃がし先（Neon Postgres）
# 未設定なら従来通り Supabase の notification_history を使う。
# 設定手順:
#   1. https://console.neon.tech でプロジェクトを作成
#   2. Neon SQL Editor で supabase/neon_schema.sql を実行
#   3. Connection Details → Pooled connection の URL を下記へ貼る
# HISTORY_STORE=supabase を明示すれば Neon を無効化できる。
HISTORY_STORE=auto
NEON_DATABASE_URL=
